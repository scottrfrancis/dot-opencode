{
  // dot-opencode global config — mirror of the ~/.claude settings.json posture,
  // adapted to OpenCode's schema. See README.md for the full Claude Code → OpenCode
  // feature map. Theme and keybinds live in tui.json (OpenCode keeps TUI config
  // separate from this file).
  "$schema": "https://opencode.ai/config.json",

  // ----------------------------------------------------------------------------
  // Models — THREE TIERS (everything else redacted; the box is moving to a single-model
  // server, so the old multi-model lists were just experimentation cruft):
  //   1. small / local  — LM Studio on THIS machine (offline + cheap ops / small_model)
  //   2. remote         — the single model on dev-ai (the RTX 4500 Blackwell box)
  //   3. cloud          — Claude (anthropic) for hard problems; needs ANTHROPIC_API_KEY
  // Default working model is the remote dev-ai model; small_model is the tiny local gemma.
  // Switch at runtime with /models. For fully offline, set "model" to "local/qwen/qwen3-coder-30b".
  // ----------------------------------------------------------------------------
  "model": "dev-ai/qwen3.6:35b-a3b",
  "small_model": "local/google/gemma-3-4b",

  "provider": {
    "dev-ai": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "RTX 4500 Blackwell 32GB (remote)",
      // Single-model server. baseURL stays :11434/v1 (Ollama) until vLLM is live on the box,
      // then flip to "http://dev-ai.local:8000/v1" (see HANDOFF-vllm-migration.md, Phase 4).
      "options": { "baseURL": "http://dev-ai.local:11434/v1" },
      "models": {
        // The one served model. Deep coder (SWE-bench 73.4), GPU-resident on the 32GB box.
        "qwen3.6:35b-a3b":                { "name": "Qwen3.6 35B-A3B (remote)",     "tools": true }
      }
    },
    "local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Razer (LM Studio)",
      "options": { "baseURL": "http://localhost:1234/v1" },
      "models": {
        // Working local coder (offline default). MoE 3B-active, non-thinking instruct.
        // Eval (Jun 2026, isolated): 4/4 coding tasks, ~17 tok/s. Best disconnected coder.
        "qwen/qwen3-coder-30b": { "name": "Qwen3 Coder 30B-A3B (local, default)", "tools": true },
        // Tiny, fully GPU-resident, ~43 tok/s — the small_model tier (titles/summaries/boilerplate).
        // Also multimodal. Not for real repo-scale work.
        "google/gemma-3-4b":    { "name": "Gemma 3 4B (local, fast/small)", "tools": true }
      }
    },

    // Cloud tier — Claude for hard problems. Needs ANTHROPIC_API_KEY in the env
    // (or run `opencode auth login`). anthropic is a built-in OpenCode provider; no npm/baseURL.
    "anthropic": {
      "name": "Claude (cloud)",
      "models": {
        "claude-opus-4-8":   { "name": "Claude Opus 4.8 (cloud, deep)" },
        "claude-sonnet-4-6": { "name": "Claude Sonnet 4.6 (cloud, fast)" }
      }
    }
    // To add Ollama on this machine, uncomment:
    // ,"ollama": {
    //   "npm": "@ai-sdk/openai-compatible",
    //   "name": "Ollama (local)",
    //   "options": { "baseURL": "http://localhost:11434/v1" },
    //   "models": { "qwen2.5-coder:7b": { "name": "Qwen2.5 Coder 7B", "tools": true } }
    // }
  },

  // ----------------------------------------------------------------------------
  // Permissions — mirrors the ~/.claude/settings.json allowlist posture:
  // ask by default, auto-allow the safe git/find/read commands, hard-deny the
  // destructive ones. The safety.js plugin enforces the denies a second time
  // at tool.execute.before (defense in depth, matching pre-tool-safety.sh).
  // OpenCode evaluates bash patterns "last match wins" — keep denies last.
  // ----------------------------------------------------------------------------
  "permission": {
    "edit": "ask",
    "webfetch": "allow",
    "bash": {
      "*": "ask",
      "find *": "allow",
      "ls *": "allow",
      "cat *": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git fetch *": "allow",
      "git config *": "allow",
      "git stash *": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git push *": "allow",
      "git checkout *": "allow",
      "rm -rf *": "deny",
      "rm -fr *": "deny",
      "git reset --hard *": "deny",
      "git push --force *": "deny",
      "git push -f *": "deny"
    }
  }

  // ----------------------------------------------------------------------------
  // MCP servers: none configured in the base. Add under an "mcp" key, e.g.
  //   "mcp": { "fetch": { "type": "local", "command": ["uvx","mcp-server-fetch"], "enabled": true } }
  // ----------------------------------------------------------------------------

  // Instructions: AGENTS.md (this repo) auto-loads as global rules. The
  // guidelines/ are referenced on-demand from AGENTS.md (kept OUT of the
  // always-on context, exactly like the ~/.claude CLAUDE.md → guidelines split).
}
